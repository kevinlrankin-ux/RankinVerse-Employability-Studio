function parseBooleanSetting_(value, fallback) { if (typeof value === 'boolean') return value; const text = String(value == null ? '' : value).trim().toLowerCase(); if (text === 'true') return true; if (text === 'false') return false; return fallback; }
function parseStringSetting_(value, fallback) { const text = String(value == null ? '' : value).trim(); return text || fallback; }
