function setSettingValue(key, value) { const cleanKey = String(key || '').trim(); if (!cleanKey) return errorResult_('INVALID_SETTING_KEY', 'Setting key is required.'); const sheetResult = openSheet_(APP_CONFIG.SHEETS.SETTINGS.SPREADSHEET_ID, APP_CONFIG.SHEETS.SETTINGS.SHEET_NAME); if (!sheetResult.ok) return sheetResult; const sheet = sheetResult.data; assertSheetHeaders(sheet, getSettingsHeaders()); const values = sheet.getDataRange().getValues(); const headers = values[0]; const rowIndex = findSettingRowIndex_(values, headers, cleanKey); if (rowIndex >= 2) { setCellByHeader_(sheet, headers, rowIndex, 'value', String(value)); return okResult_({ key: cleanKey, value: String(value), action: 'updated' }, 'Setting updated.'); } sheet.appendRow([cleanKey, String(value)]); return okResult_({ key: cleanKey, value: String(value), action: 'created' }, 'Setting created.'); }
